from io import StringIO


def show_ase_atoms_3d(atoms, width=500, height=400):
    buf = StringIO()
    write(buf, atoms, format="xyz")
    xyz = buf.getvalue()

    view = py3Dmol.view(width=width, height=height)
    view.addModel(xyz, "xyz")
    view.setStyle(
        {
            "stick": {"radius": 0.15},
            "sphere": {"scale": 0.28},
        }
    )
    view.zoomTo()
    return view.show()

